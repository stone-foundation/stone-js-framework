{
  "name": "@stone-js/create",
  "version": "0.8.0",
  "description": "Scaffold a new Stone.js app in seconds using your terminal.",
  "author": "Mr. Stone <evensstone@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stone-foundation/stone-js-framework.git",
    "directory": "stone-js"
  },
  "homepage": "https://stonejs.dev",
  "bugs": {
    "url": "https://github.com/stone-foundation/stone-js-framework/issues"
  },
  "keywords": [
    "stone",
    "create-stone",
    "scaffold",
    "starter",
    "templates",
    "stone.js",
    "stonejs",
    "cli",
    "initializer"
  ],
  "files": [
    "bin"
  ],
  "bin": {
    "create-stone": "bin/create-stone.mjs"
  },
  "type": "module",
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:cvg": "npm run test -- --coverage",
    "test:text": "npm run test:cvg -- --coverage.reporter=text",
    "test:html": "npm run test:cvg -- --coverage.reporter=html",
    "test:clover": "npm run test:cvg -- --coverage.reporter=clover",
    "prepare": "husky"
  },
  "dependencies": {
    "cross-spawn": "^7.0.6",
    "@stone-js/cli": "workspace:*"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@vitest/coverage-v8": "^3.2.4",
    "husky": "^9.1.7",
    "vitest": "^3.2.4"
  }
}
