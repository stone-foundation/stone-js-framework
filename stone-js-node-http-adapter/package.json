{
  "name": "@stone-js/node-http-adapter",
  "version": "0.8.2",
  "description": "Node HTTP adapter for Stone.js. Run your app on any Node.js HTTP server using the Continuum Architecture.",
  "author": "Mr. Stone <evensstone@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stone-foundation/stone-js-framework.git",
    "directory": "stone-js-node-http-adapter"
  },
  "homepage": "https://stonejs.dev",
  "bugs": {
    "url": "https://github.com/stone-foundation/stone-js-framework/issues"
  },
  "keywords": [
    "node",
    "http",
    "server",
    "bridge",
    "driver",
    "runner",
    "adapter",
    "Stone.js",
    "connector"
  ],
  "files": [
    "/dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/index.d.ts",
        "default": "./dist/browser.js"
      },
      "default": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "lint": "ts-standard src",
    "lint:fix": "ts-standard --fix src tests",
    "predoc": "rimraf docs",
    "doc": "typedoc",
    "clean": "rimraf dist",
    "build": "rollup -c",
    "test": "vitest run",
    "test:cvg": "npm run test -- --coverage",
    "test:text": "npm run test:cvg -- --coverage.reporter=text",
    "test:html": "npm run test:cvg -- --coverage.reporter=html",
    "test:clover": "npm run test:cvg -- --coverage.reporter=clover",
    "prepare": "husky"
  },
  "peerDependencies": {
    "@stone-js/core": "workspace:*",
    "@stone-js/filesystem": "workspace:*",
    "@stone-js/http-core": "workspace:*"
  },
  "dependencies": {
    "@stone-js/config": "workspace:*",
    "accepts": "^1.3.8",
    "bytes": "^3.1.2",
    "chalk": "^5.4.1",
    "co-body": "^6.2.0",
    "connect": "^3.7.0",
    "content-type": "^1.0.5",
    "mime": "^4.0.7",
    "proxy-addr": "^2.0.7",
    "raw-body": "^3.0.0",
    "statuses": "^2.0.1",
    "type-is": "^2.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-multi-entry": "^6.0.1",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/accepts": "^1.3.7",
    "@types/bytes": "^3.1.5",
    "@types/co-body": "^6.1.3",
    "@types/connect": "^3.4.38",
    "@types/content-type": "^1.1.8",
    "@types/node": "^24.0.1",
    "@types/proxy-addr": "^2.0.3",
    "@types/statuses": "^2.0.5",
    "@types/type-is": "^1.6.7",
    "@vitest/coverage-v8": "^3.2.4",
    "husky": "^9.1.7",
    "rimraf": "^6.0.1",
    "rollup": "^4.44.1",
    "rollup-plugin-node-externals": "^8.0.1",
    "ts-standard": "^12.0.2",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.6",
    "typedoc-plugin-markdown": "^4.7.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  },
  "ts-standard": {
    "globals": [
      "it",
      "test",
      "expect",
      "describe",
      "beforeEach"
    ]
  }
}
