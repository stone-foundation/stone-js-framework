{
  "name": "@stone-js/router",
  "version": "0.8.4",
  "description": "Stone.js router for both Node.js and browser environments, designed for serverless applications.",
  "author": "Mr. Stone <evensstone@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stone-foundation/stone-js-framework.git",
    "directory": "stone-js-router"
  },
  "homepage": "https://stonejs.dev",
  "bugs": {
    "url": "https://github.com/stone-foundation/stone-js-framework/issues"
  },
  "keywords": [
    "node",
    "worker",
    "browser",
    "Stone.js",
    "router",
    "serverless"
  ],
  "files": [
    "/dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "lint": "ts-standard src",
    "lint:fix": "ts-standard --fix src tests",
    "predoc": "rimraf docs",
    "doc": "typedoc",
    "clean": "rimraf dist",
    "build": "rollup -c",
    "test": "vitest run",
    "test:cvg": "npm run test -- --coverage",
    "test:text": "npm run test:cvg -- --coverage.reporter=text",
    "test:html": "npm run test:cvg -- --coverage.reporter=html",
    "test:clover": "npm run test:cvg -- --coverage.reporter=clover",
    "prepare": "husky"
  },
  "peerDependencies": {
    "@stone-js/core": "workspace:*",
    "@stone-js/pipeline": "workspace:*"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-multi-entry": "^6.0.1",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^24.0.7",
    "@vitest/coverage-v8": "^3.2.4",
    "husky": "^9.1.7",
    "rimraf": "^6.1.2",
    "rollup": "^4.53.3",
    "rollup-plugin-node-externals": "^8.1.2",
    "ts-standard": "^12.0.2",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.15",
    "typedoc-plugin-markdown": "^4.7.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "ts-standard": {
    "globals": [
      "it",
      "test",
      "expect",
      "describe",
      "beforeEach"
    ]
  }
}
