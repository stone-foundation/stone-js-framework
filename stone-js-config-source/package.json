{
  "name": "@stone-js/config-source",
  "version": "0.8.4",
  "description": "Agnostic configuration sources for Stone.js: load and merge config from env, files (json/yaml), AWS SSM, Secrets Manager, HTTP/GitHub and KMS-decrypted values into the blueprint before boot, with optional live reload.",
  "author": "Mr. Stone <evensstone@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stone-foundation/stone-js-framework.git",
    "directory": "stone-js-config-source"
  },
  "homepage": "https://stonejs.dev",
  "bugs": {
    "url": "https://github.com/stone-foundation/stone-js-framework/issues"
  },
  "keywords": [
    "stonejs",
    "config",
    "configuration",
    "ssm",
    "secrets-manager",
    "kms",
    "env",
    "yaml",
    "cloud-config",
    "live-config"
  ],
  "files": [
    "/dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "lint": "ts-standard src",
    "lint:fix": "ts-standard --fix src tests",
    "predoc": "rimraf docs",
    "doc": "typedoc",
    "clean": "rimraf dist",
    "build": "rollup -c",
    "test": "vitest run",
    "test:cvg": "npm run test -- --coverage",
    "test:text": "npm run test:cvg -- --coverage.reporter=text",
    "test:html": "npm run test:cvg -- --coverage.reporter=html",
    "test:clover": "npm run test:cvg -- --coverage.reporter=clover",
    "prepare": "husky"
  },
  "peerDependencies": {
    "@stone-js/core": "workspace:*",
    "@aws-sdk/client-ssm": "^3.0.0",
    "@aws-sdk/client-secrets-manager": "^3.0.0",
    "@aws-sdk/client-kms": "^3.0.0",
    "js-yaml": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-ssm": {
      "optional": true
    },
    "@aws-sdk/client-secrets-manager": {
      "optional": true
    },
    "@aws-sdk/client-kms": {
      "optional": true
    },
    "js-yaml": {
      "optional": true
    }
  },
  "dependencies": {
    "@stone-js/config": "workspace:*"
  },
  "devDependencies": {
    "@aws-sdk/client-kms": "^3.700.0",
    "@aws-sdk/client-secrets-manager": "^3.700.0",
    "@aws-sdk/client-ssm": "^3.700.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-multi-entry": "^6.0.1",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.4",
    "@stone-js/core": "workspace:*",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.7",
    "@vitest/coverage-v8": "^3.2.4",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.0",
    "rimraf": "^6.0.1",
    "rollup": "^4.44.1",
    "rollup-plugin-node-externals": "^8.0.1",
    "ts-standard": "^12.0.2",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.6",
    "typedoc-plugin-markdown": "^4.7.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  },
  "ts-standard": {
    "globals": [
      "it",
      "test",
      "vi",
      "expect",
      "describe",
      "beforeEach",
      "afterEach"
    ]
  }
}
