{
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ],
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "module": "ESNext",
    "target": "ESNext",
    "declaration": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "vitest/globals"]
  }
}
