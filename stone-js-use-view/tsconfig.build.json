{
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "tests/**/*.ts"
  ],
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "outDir": "./dist",
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "emitDeclarationOnly": false,
    "types": ["node"],
    "allowSyntheticDefaultImports": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "forceConsistentCasingInFileNames": true
  }
}
