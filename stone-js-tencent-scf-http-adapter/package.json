{
  "name": "@stone-js/tencent-scf-http-adapter",
  "version": "0.8.0",
  "description": "Tencent Cloud SCF HTTP adapter for Stone.js. Run your app on Serverless Cloud Function HTTP triggers (API Gateway proxy integration) using the Continuum Architecture.",
  "author": "Mr. Stone <evensstone@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stone-foundation/stone-js-framework.git",
    "directory": "stone-js-tencent-scf-http-adapter"
  },
  "homepage": "https://stonejs.dev",
  "bugs": {
    "url": "https://github.com/stone-foundation/stone-js-framework/issues"
  },
  "keywords": [
    "tencent",
    "tencent-cloud",
    "scf",
    "serverless-cloud-function",
    "api-gateway",
    "faas",
    "serverless",
    "http",
    "china",
    "adapter",
    "Stone.js"
  ],
  "files": [
    "/dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "lint": "ts-standard src",
    "lint:fix": "ts-standard --fix src tests",
    "predoc": "rimraf docs",
    "doc": "typedoc",
    "clean": "rimraf dist",
    "build": "rollup -c",
    "test": "vitest run",
    "test:cvg": "npm run test -- --coverage",
    "test:text": "npm run test:cvg -- --coverage.reporter=text",
    "test:html": "npm run test:cvg -- --coverage.reporter=html",
    "test:clover": "npm run test:cvg -- --coverage.reporter=clover",
    "prepare": "husky"
  },
  "peerDependencies": {
    "@stone-js/core": "workspace:*",
    "@stone-js/env": "workspace:*",
    "@stone-js/filesystem": "workspace:*",
    "@stone-js/http-core": "workspace:*"
  },
  "dependencies": {
    "@stone-js/config": "workspace:*",
    "accepts": "^1.3.8",
    "bytes": "^3.1.2",
    "content-type": "^1.0.5",
    "mime": "^4.1.0",
    "proxy-addr": "^2.0.7",
    "statuses": "^2.0.1",
    "type-is": "^2.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-multi-entry": "^6.0.1",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/accepts": "^1.3.7",
    "@types/bytes": "^3.1.5",
    "@types/content-type": "^1.1.8",
    "@types/node": "^24.9.2",
    "@types/proxy-addr": "^2.0.3",
    "@types/statuses": "^2.0.5",
    "@types/type-is": "^1.6.7",
    "@vitest/coverage-v8": "^3.2.4",
    "husky": "^9.1.7",
    "rimraf": "^6.1.0",
    "rollup": "^4.52.5",
    "rollup-plugin-node-externals": "^8.1.1",
    "ts-standard": "^12.0.2",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.14",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "ts-standard": {
    "globals": [
      "it",
      "test",
      "expect",
      "describe",
      "beforeEach"
    ]
  }
}
