# Stone.js monorepo — pnpm settings.
# Une seule instance résolue de @stone-js/core (corrige la double-instance / Symbol.metadata).
dedupe-peer-dependents=true
strict-peer-dependencies=false
# Les paquets internes se lient via le workspace en priorité.
link-workspace-packages=true
prefer-workspace-packages=true
save-workspace-protocol=rolling
